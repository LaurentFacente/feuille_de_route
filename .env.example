# =============================================================================
# Variables d'environnement — Feuille de route
# Copier ce fichier en `.env` (local) et configurer les mêmes clés sur Vercel.
# =============================================================================

# --- Frontend (exposées au navigateur via Vite, préfixe VITE_) ---------------
# URL du projet Supabase (Dashboard > Project Settings > API > Project URL)
VITE_SUPABASE_URL="https://VOTRE-PROJET.supabase.co"

# Clé publique "anon" (Dashboard > Project Settings > API > anon public)
# Sûre à exposer côté client : la sécurité repose sur les policies RLS.
VITE_SUPABASE_ANON_KEY="VOTRE_ANON_KEY"

# Identifiant du projet de tournage chargé par défaut dans l'app.
VITE_PROJECT_ID="tehazed"

# --- Seed / scripts serveur (NE JAMAIS exposer au client / committer) --------
# Mêmes valeurs que ci-dessus, utilisées par les scripts Node (seed).
SUPABASE_URL="https://VOTRE-PROJET.supabase.co"

# Clé "service_role" (Dashboard > Project Settings > API > service_role secret)
# Contourne les RLS : usage strictement serveur (migrations, seed, CI).
SUPABASE_SERVICE_ROLE_KEY="VOTRE_SERVICE_ROLE_KEY"
